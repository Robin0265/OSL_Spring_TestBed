    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File with my args",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/.pixi/envs/default/python.exe",
            "env": {
                "PYTHONNOUSERSITE": "1"
            },
            // "args": [
            //     "--username", "Jeremy",
            //     "--account", "Stackoverflow"
            // ],
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Current File with UserName arg",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/.pixi/envs/default/python.exe",
            "env": {
                "PYTHONNOUSERSITE": "1"
            },
            "args": ["${env:USERNAME}"],
            "console": "integratedTerminal"
        }, 
        
    ], 
    "sudo": true
}
